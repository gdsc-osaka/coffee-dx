{
  "name": "web",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "cd:typegen": "react-router typegen",
    "typecheck": "pnpm run cd:typegen && tsc",
    "check": "pnpm lint && pnpm format:check",
    "deploy": "react-router build && wrangler deploy",
    "db:generate": "drizzle-kit generate",
    "migrate:local": "wrangler d1 migrations apply coffee-dx-db --local",
    "migrate:remote": "wrangler d1 migrations apply coffee-dx-db --remote"
  },
  "dependencies": {
    "@react-router/cloudflare": "7.13.2",
    "drizzle-orm": "^0.45.2",
    "isbot": "^5.1.36",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "7.13.2"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.0.0",
    "@cloudflare/workers-types": "^4.20240405.0",
    "@react-router/dev": "7.13.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.10",
    "oxfmt": "^0.43.0",
    "oxlint": "^0.15.11",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "vite": "^8.0.3",
    "vite-tsconfig-paths": "^5.1.4",
    "wrangler": "^4.79.0"
  }
}
